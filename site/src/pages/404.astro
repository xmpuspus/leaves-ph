---
import Base from "../layouts/Base.astro";
---
<Base title="Leaves.PH · page not found" pathname="/404">
  <article class="max-w-prose mx-auto px-5 sm:px-8 pt-20 pb-24 text-ink-700 leading-[1.7] text-center">
    <p class="kicker mb-4 text-sepia-500">404 &middot; PAGE NOT FOUND</p>
    <h1 class="font-display font-medium tracking-tight text-ink-900 mb-5" style="font-size: clamp(2rem, 4.5vw, 3rem); line-height: 1.05;">
      This page isn't on the map.
    </h1>
    <p class="mb-8 text-[15px] max-w-[46ch] mx-auto">
      The link may be mistyped or the page may have moved. Head back to the
      interactive canopy map and find your barangay from there.
    </p>
    <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm font-mono uppercase tracking-[0.14em]">
      <a href="/" class="text-umber-700 no-underline">the map</a>
      <a href="/report" class="text-umber-700 no-underline">the report</a>
      <a href="/accountability" class="text-umber-700 no-underline">accountability</a>
      <a href="/faq" class="text-umber-700 no-underline">faq</a>
    </div>
  </article>
</Base>
