---
import Base from "../layouts/Base.astro";
import MapView from "../components/MapView.astro";
---
<Base title="Leaves.PH · the map" pathname="/map">
  <section class="max-w-6xl mx-auto px-6 pt-10 pb-4">
    <p class="text-xs uppercase tracking-[0.2em] text-ink-500 mb-3 font-mono">Leaves.PH &middot; per-LGU canopy 2016 to 2026</p>
    <h1 class="text-3xl md:text-4xl leading-[1.05] mb-3 text-ink-900 font-semibold tracking-tight">
      17 LGUs, 11 years, one reconciled measurement.
    </h1>
    <p class="text-base text-ink-700 leading-relaxed max-w-prose">
      Click an LGU to see its 2016 to 2026 canopy curve. Slide the year control to watch the per-LGU change. The headline strip at the top reconciles the NCR-wide aggregate against the four 2024+ public figures.
    </p>
  </section>
  <MapView />
</Base>
