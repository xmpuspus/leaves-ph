---
interface Props {
  pathname: string;
}
const { pathname } = Astro.props;

const links = [
  { href: "/", label: "the report" },
  { href: "/map", label: "the map" },
  { href: "/methodology", label: "methodology" },
  { href: "/data", label: "data" },
  { href: "/faq", label: "faq" },
  { href: "/privacy", label: "privacy" },
];

const today = new Date().toISOString().slice(0, 10);
---
<header class="border-b border-ink-900 bg-paper">
  <div class="max-w-6xl mx-auto px-5 sm:px-8">
    <div class="flex items-baseline justify-between py-3 border-b border-ink-300/50">
      <span class="kicker">VOL. 1 &middot; NCR &middot; {today}</span>
      <a href="https://github.com/xmpuspus/leaves-ph" class="kicker no-underline text-ink-500 hover:text-forest-700">
        github &nbsp;&rarr;
      </a>
    </div>
    <div class="flex flex-wrap items-end justify-between py-4 gap-y-3">
      <a href="/" class="no-underline group">
        <h1 class="font-display text-3xl sm:text-4xl font-medium tracking-tight text-ink-900 leading-none">
          Leaves<span class="text-forest-700">.</span>PH
        </h1>
        <p class="kicker mt-1 text-ink-500">A reconciled satellite measurement</p>
      </a>
      <nav class="flex flex-wrap gap-x-5 gap-y-1 text-sm font-sans">
        {links.map((link) => {
          const active = pathname === link.href || (link.href !== "/" && pathname.startsWith(link.href));
          return (
            <a
              href={link.href}
              class={`no-underline pb-1 ${active ? "text-ink-900 border-b-2 border-forest-700 font-medium" : "text-ink-500 hover:text-ink-900"}`}
            >
              {link.label}
            </a>
          );
        })}
      </nav>
    </div>
  </div>
</header>
