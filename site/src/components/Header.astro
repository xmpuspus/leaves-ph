---
interface Props {
  pathname: string;
}
const { pathname } = Astro.props;

const links = [
  { href: "/", label: "Metro Manila" },
  { href: "/map", label: "the map" },
  { href: "/methodology", label: "methodology" },
  { href: "/data", label: "data" },
  { href: "/faq", label: "faq" },
  { href: "/privacy", label: "privacy" },
];
---
<header class="border-b border-ink-300/30 bg-paper">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3 sm:py-4 flex flex-wrap items-center gap-x-4 gap-y-2 justify-between">
    <a href="/" class="font-semibold tracking-tight no-underline text-ink-900 shrink-0">
      Leaves.PH
    </a>
    <nav class="flex flex-wrap gap-x-3 sm:gap-x-5 gap-y-1 text-sm">
      {links.map((link) => (
        <a
          href={link.href}
          class={`no-underline ${pathname === link.href || (link.href !== "/" && pathname.startsWith(link.href)) ? "text-ink-900 font-medium" : "text-ink-500 hover:text-ink-900"}`}
        >
          {link.label}
        </a>
      ))}
      <a href="https://github.com/xmpuspus/leaves-ph" class="text-ink-500 no-underline hover:text-ink-900">github</a>
    </nav>
  </div>
</header>
