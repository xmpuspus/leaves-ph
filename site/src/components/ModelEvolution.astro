---
import { MODEL_EVOLUTION as ME, F1_V2, F1_V3 } from "../lib/modelEvolution";

const versions = ME;

// Chart geometry. Wide viewBox; the SVG scales to fill its container width.
const W = 820,
  H = 440;
const m = { top: 52, right: 28, bottom: 76, left: 60 };
const plotW = W - m.left - m.right;
const plotH = H - m.top - m.bottom;
const n = versions.length;
const yMin = 0.65,
  yMax = 0.9;

const x = (i: number) => m.left + (n === 1 ? 0 : (i / (n - 1)) * plotW);
const y = (v: number) => m.top + (1 - (v - yMin) / (yMax - yMin)) * plotH;

const pts = versions.map((d, i) => ({ ...d, cx: x(i), cy: y(d.metric), i }));
const clf = pts.filter((p) => p.track === "classification");
const reg = pts.filter((p) => p.track === "regression");
const line = (ps: typeof pts) => ps.map((p, k) => `${k === 0 ? "M" : "L"}${p.cx.toFixed(1)},${p.cy.toFixed(1)}`).join(" ");

// Pivot divider sits between the last classifier and first regressor version.
const pivotX = (clf[clf.length - 1].cx + reg[0].cx) / 2;
const gridVals = [0.7, 0.75, 0.8, 0.85, 0.9];
const deployed = pts.find((p) => p.deployed)!;
const f1Gain = ((F1_V3 - F1_V2) * 100).toFixed(1);
---

<figure class="my-2">
  <figcaption class="mb-4">
    <p class="kicker text-ink-500 mb-2">FIG · MODEL EVOLUTION · v2 &rarr; v9</p>
    <p class="font-display text-2xl text-ink-900 leading-tight mb-2">
      Eight model versions, two tasks, one rising line
    </p>
    <p class="text-sm text-ink-700 max-w-prose leading-relaxed">
      The classifier track (v2&ndash;v5) scores 5-fold cross-validated <strong>F1</strong> on a
      binary tree / not-tree label. At v6 the task changed to predicting <strong>canopy
      fraction</strong> against Meta's 1&nbsp;m reference, scored by <strong>R&sup2;</strong>.
      F1 and R&sup2; are different metrics on different tasks, so this is two tracks, not one curve.
    </p>
  </figcaption>

  <div class="border border-ink-900 bg-paper-tint/40 p-3 sm:p-5">
    <svg
      viewBox={`0 0 ${W} ${H}`}
      class="w-full h-auto"
      role="img"
      aria-labelledby="me-title me-desc"
      preserveAspectRatio="xMidYMid meet"
    >
      <title id="me-title">Model accuracy across versions v2 to v9</title>
      <desc id="me-desc">
        Classification F1 rises from 0.69 at v2 to 0.78 at v3 then holds near 0.77 through v5. After
        the task pivot at v6, regression R-squared climbs from 0.71 at v6 to 0.78 at v7 to 0.87 at the
        deployed v9 model.
      </desc>

      <!-- gridlines + y labels -->
      {
        gridVals.map((g) => (
          <g>
            <line x1={m.left} y1={y(g)} x2={W - m.right} y2={y(g)} stroke="#a7a094" stroke-width="0.5" stroke-dasharray="2 3" opacity="0.6" />
            <text x={m.left - 10} y={y(g) + 3.5} text-anchor="end" class="me-axis">{g.toFixed(2)}</text>
          </g>
        ))
      }
      <text
        transform={`translate(16 ${m.top + plotH / 2}) rotate(-90)`}
        text-anchor="middle"
        class="me-axis-title">cross-validated score</text>

      <!-- task-pivot divider -->
      <line x1={pivotX} y1={m.top - 6} x2={pivotX} y2={m.top + plotH} stroke="#1a1a1a" stroke-width="1" stroke-dasharray="4 4" opacity="0.4" />
      <text x={pivotX} y={m.top - 12} text-anchor="middle" class="me-pivot">task pivot &middot; classify &rarr; regress</text>

      <!-- classification segment -->
      <path d={line(clf)} fill="none" stroke="#b65724" stroke-width="2.5" stroke-linejoin="round" class="me-path" />
      <!-- regression segment -->
      <path d={line(reg)} fill="none" stroke="#1f3d2b" stroke-width="2.5" stroke-linejoin="round" class="me-path" />

      <!-- points + direct value labels + version ticks -->
      {
        pts.map((p) => (
          <g>
            <circle
              cx={p.cx}
              cy={p.cy}
              r={p.deployed ? 7 : 4.5}
              fill={p.track === "classification" ? "#b65724" : "#1f3d2b"}
              stroke="#f7f3e9"
              stroke-width="1.5"
            />
            <text x={p.cx} y={p.cy - 14} text-anchor="middle" class={p.deployed ? "me-val me-val-strong" : "me-val"}>
              {p.metric.toFixed(p.deployed ? 2 : 2)}
            </text>
            <text x={p.cx} y={m.top + plotH + 22} text-anchor="middle" class="me-version">{p.version}</text>
            <text x={p.cx} y={m.top + plotH + 38} text-anchor="middle" class="me-metric-tag">
              {p.metricLabel}
            </text>
          </g>
        ))
      }

      <!-- deployed callout -->
      <g>
        <line x1={deployed.cx} y1={deployed.cy - 24} x2={deployed.cx} y2={deployed.cy - 8} stroke="#1f3d2b" stroke-width="1" opacity="0.5" />
        <text x={deployed.cx} y={deployed.cy - 30} text-anchor="middle" class="me-deployed">DEPLOYED · held-out R&sup2;</text>
      </g>
    </svg>

    <!-- legend -->
    <div class="flex flex-wrap items-center gap-x-6 gap-y-2 mt-3 pt-3 border-t border-ink-300/60 font-mono text-[11px] uppercase tracking-[0.12em] text-ink-500">
      <span class="flex items-center gap-2"><span class="inline-block w-5 h-[3px]" style="background:#b65724"></span>Classification F1 (v2&ndash;v5)</span>
      <span class="flex items-center gap-2"><span class="inline-block w-5 h-[3px]" style="background:#1f3d2b"></span>Regression R&sup2; vs Meta 1&thinsp;m (v6&ndash;v9)</span>
      <span class="ml-auto text-ink-700 normal-case tracking-normal">Adding the ESA teacher at v3 lifted F1 by {f1Gain} points.</span>
    </div>
  </div>
</figure>

<style>
  .me-axis { font-family: "JetBrains Mono", monospace; font-size: 11px; fill: #6a6a6a; }
  .me-axis-title { font-family: "JetBrains Mono", monospace; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; fill: #6a6a6a; }
  .me-pivot { font-family: "JetBrains Mono", monospace; font-size: 9.5px; letter-spacing: 0.1em; text-transform: uppercase; fill: #6a6a6a; }
  .me-version { font-family: "JetBrains Mono", monospace; font-size: 13px; font-weight: 600; fill: #1a1a1a; }
  .me-metric-tag { font-family: "JetBrains Mono", monospace; font-size: 9px; letter-spacing: 0.08em; text-transform: uppercase; fill: #a7a094; }
  .me-val { font-family: "JetBrains Mono", monospace; font-size: 12px; fill: #3a3a3a; }
  .me-val-strong { font-size: 15px; font-weight: 700; fill: #1f3d2b; }
  .me-deployed { font-family: "JetBrains Mono", monospace; font-size: 9px; letter-spacing: 0.12em; fill: #1f3d2b; font-weight: 600; }

  .me-path { stroke-dasharray: 1000; stroke-dashoffset: 1000; animation: me-draw 1.1s ease-out forwards; }
  @keyframes me-draw { to { stroke-dashoffset: 0; } }
  @media (prefers-reduced-motion: reduce) {
    .me-path { animation: none; stroke-dashoffset: 0; }
  }
</style>
