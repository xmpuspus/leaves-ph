---
// Editorial map: full-bleed MapLibre canvas, three stacked data layers
// (Meta canopy raster, per-LGU choropleth, individual tree-crown vectors),
// sticky year-slider header, slide-over LGU sheet.
//
// Layers:
//   1. OSM raster basemap (desaturated)
//   2. Meta canopy height >= 5 m raster tiles (z11-14) - the granularity layer
//   3. Tree-crown vector pmtiles (z11-16) - 242,810 individual canopy polygons
//   4. Per-LGU choropleth (color follows year slider)
---
<div class="border-t border-b border-ink-900 bg-paper">
  <!-- Sticky year slider strip -->
  <div class="sticky top-0 z-30 bg-paper border-b border-ink-900">
    <div class="max-w-6xl mx-auto px-5 sm:px-8 py-3 grid md:grid-cols-[1fr_minmax(180px,2fr)_1fr] gap-4 items-center">
      <div class="flex items-baseline gap-3">
        <span class="kicker text-ink-500">YEAR</span>
        <span id="year-label" class="font-display font-medium text-3xl tabular-nums text-ink-900 leading-none">2026</span>
      </div>
      <input id="year-slider" type="range" min="2019" max="2026" step="1" value="2026" class="editorial-slider w-full" />
      <div class="font-mono text-[11px] uppercase tracking-[0.15em] text-ink-500 flex justify-between md:justify-end gap-3">
        <span>2019</span>
        <span class="text-ink-300">|</span>
        <span>2026</span>
      </div>
    </div>
  </div>

  <!-- Headline strip: four KPIs in editorial-table layout (no card grid) -->
  <div class="max-w-6xl mx-auto px-5 sm:px-8 py-6 grid grid-cols-2 md:grid-cols-4 gap-x-8 gap-y-4 divide-x divide-ink-300">
    <div class="pl-0">
      <p class="kicker text-ink-500 mb-1.5">NCR &middot; SELECTED YEAR</p>
      <p id="strip-total-pct" class="stat-medium leading-none">--</p>
      <p id="strip-total-ha" class="font-mono text-[11px] mt-2 text-ink-500 leading-relaxed">--</p>
    </div>
    <div class="pl-6">
      <p class="kicker text-ink-500 mb-1.5">2019 to 2026 DELTA</p>
      <p id="strip-delta" class="stat-medium leading-none">--</p>
      <p class="font-mono text-[11px] mt-2 text-ink-500 leading-relaxed">percentage points</p>
    </div>
    <div class="pl-6">
      <p class="kicker text-ink-500 mb-1.5">VS DENR 6&middot;0%</p>
      <p id="strip-vs-denr" class="stat-medium leading-none">--</p>
      <p class="font-mono text-[11px] mt-2 text-ink-500 leading-relaxed">2026 only</p>
    </div>
    <div class="pl-6">
      <p class="kicker text-ink-500 mb-1.5">VS GFW 4&middot;0%</p>
      <p id="strip-vs-gfw" class="stat-medium leading-none">--</p>
      <p class="font-mono text-[11px] mt-2 text-ink-500 leading-relaxed">2026 only</p>
    </div>
  </div>
</div>

<!-- Layer toggles + full-bleed map -->
<section class="border-b border-ink-900">
  <div class="max-w-6xl mx-auto px-5 sm:px-8 py-3 flex flex-wrap gap-x-4 gap-y-2 items-center justify-between border-b border-ink-300">
    <div class="flex flex-wrap gap-x-4 gap-y-1 items-center font-mono text-[11px] uppercase tracking-[0.15em] text-ink-700">
      <span class="text-ink-500">LAYERS:</span>
      <label class="flex items-center gap-1.5 cursor-pointer"><input type="checkbox" id="layer-meta" checked class="accent-forest-700" />Meta canopy 1 m</label>
      <label class="flex items-center gap-1.5 cursor-pointer"><input type="checkbox" id="layer-crowns" checked class="accent-forest-700" />Tree crowns (242k)</label>
      <label class="flex items-center gap-1.5 cursor-pointer"><input type="checkbox" id="layer-lgus" checked class="accent-forest-700" />LGU choropleth</label>
    </div>
    <p class="font-mono text-[10px] text-ink-500 uppercase tracking-[0.12em]">click any LGU for the curve &nbsp;&middot;&nbsp; zoom 14+ for crowns</p>
  </div>
  <div id="map" class="w-full h-[640px] bg-paper-tint"></div>
</section>

<!-- Per-LGU rankings table beneath the map (no card grid; magazine table) -->
<section class="max-w-6xl mx-auto px-5 sm:px-8 py-10 grid md:grid-cols-editorial-wide gap-x-12 gap-y-8">
  <div>
    <p class="kicker text-ink-500 mb-3">FIG&nbsp;2 &middot; LGU CANOPY 2026 &middot; SORTED HIGH TO LOW</p>
    <table class="w-full text-sm font-mono tabular-nums">
      <thead class="border-b border-ink-900">
        <tr class="text-left text-[11px] uppercase tracking-[0.12em] text-ink-500">
          <th class="py-2 font-medium">LGU</th>
          <th class="py-2 font-medium text-right">2026</th>
          <th class="py-2 font-medium text-right">DELTA</th>
        </tr>
      </thead>
      <tbody id="lgu-table-body" class="divide-y divide-ink-300/50"></tbody>
    </table>
  </div>
  <aside class="max-w-narrow">
    <p class="kicker text-ink-500 mb-3">READING NOTE</p>
    <p class="text-sm leading-[1.7] text-ink-700">
      Quezon City carries the NCR average. The La Mesa watershed, UP Diliman campus, and the Wack Wack greens together hold an 18.93 percent canopy in 2026. Drop QC and the NCR figure halves.
    </p>
    <p class="text-sm leading-[1.7] text-ink-700 mt-4">
      Manila, Navotas, and Pasay are <span class="font-medium">structurally low</span>: dense reclamation and historic urban core. Their canopy will not change by methodology choice; it is just very low.
    </p>
    <p class="text-sm leading-[1.7] text-ink-700 mt-4">
      Taguig, Malabon, Las Pinas, and Valenzuela are the steepest 2019 to 2026 decliners. Construction-heavy southern and northern fringes.
    </p>
  </aside>
</section>

<!-- SLIDE-OVER LGU DETAIL SHEET (right-anchored) -->
<aside id="lgu-sheet" class="fixed inset-y-0 right-0 w-full max-w-md bg-paper border-l border-ink-900 transform translate-x-full transition-transform duration-300 z-50 overflow-y-auto shadow-xl">
  <div class="border-b border-ink-900 px-5 py-3 flex items-baseline justify-between sticky top-0 bg-paper">
    <p class="kicker text-ink-500">LGU DOSSIER</p>
    <button id="lgu-sheet-close" class="font-mono text-sm text-ink-700 hover:text-forest-700">close &times;</button>
  </div>
  <div class="px-5 py-5">
    <p class="kicker text-ink-500">NATIONAL CAPITAL REGION</p>
    <h2 id="lgu-name" class="font-display text-display-2 text-ink-900 mt-1 mb-6 leading-none">--</h2>

    <div class="grid grid-cols-2 gap-x-6 gap-y-5 border-y border-ink-900 py-5">
      <div>
        <p class="kicker text-ink-500 mb-1" id="lgu-pct-year-label">2026 CANOPY</p>
        <p id="lgu-pct" class="font-display font-medium text-3xl text-forest-700 tabular-nums leading-none">--</p>
        <p id="lgu-ha" class="font-mono text-[10px] text-ink-500 mt-1.5 leading-relaxed">--</p>
      </div>
      <div>
        <p class="kicker text-ink-500 mb-1">2019 to 2026 DELTA</p>
        <p id="lgu-delta" class="font-display font-medium text-3xl text-umber-700 tabular-nums leading-none">--</p>
        <p class="font-mono text-[10px] text-ink-500 mt-1.5 leading-relaxed">percentage points</p>
      </div>
    </div>

    <p class="kicker text-ink-500 mt-6 mb-3">8-YEAR CURVE</p>
    <svg id="lgu-curve" viewBox="0 0 320 90" class="w-full h-24" preserveAspectRatio="none"></svg>

    <div class="mt-6 pt-5 border-t border-ink-300 space-y-4">
      <div class="flex items-baseline justify-between">
        <p class="kicker text-ink-500">HANSEN LOSS 2001-2025</p>
        <p id="lgu-hansen" class="font-mono font-medium tabular-nums text-ink-900">--</p>
      </div>
      <div class="flex items-baseline justify-between">
        <p class="kicker text-ink-500">ESA 2021 CROSS-CHECK</p>
        <p id="lgu-esa" class="font-mono font-medium tabular-nums text-ink-900">--</p>
      </div>
    </div>
  </div>
</aside>

<script>
  import maplibregl from "maplibre-gl";
  import "maplibre-gl/dist/maplibre-gl.css";
  import { interpolateYlGn } from "d3-scale-chromatic";

  const DATA_BASE = "/data";
  const YEARS = Array.from({ length: 8 }, (_, i) => 2019 + i);
  const MAX_PCT_FOR_COLOR = 22;
  const REF_PCT = { denr_cited: 6.0, gfw_dashboard: 4.0 };
  const FOREST_GREEN = "#1f3d2b";
  // const UMBER = "#b65724";
  const INK = "#1a1a1a";

  function colorForPct(pct: number | null | undefined): string {
    if (pct == null) return "#efe9d8";
    const t = Math.max(0, Math.min(1, pct / MAX_PCT_FOR_COLOR));
    return interpolateYlGn(0.15 + t * 0.85);
  }
  function fmtPct(n: number | null | undefined, digits = 2): string {
    return n == null ? "n/a" : `${n.toFixed(digits)}%`;
  }
  function fmtHa(n: number | null | undefined): string {
    if (n == null) return "n/a";
    if (n >= 10000) return `${(n / 1000).toFixed(1)} kha`;
    return `${Math.round(n).toLocaleString()} ha`;
  }
  function fmtDelta(n: number | null | undefined): string {
    if (n == null) return "n/a";
    const sign = n > 0 ? "+" : "";
    return `${sign}${n.toFixed(2)}pp`;
  }

  async function loadJSON<T = any>(path: string): Promise<T> {
    const r = await fetch(`${DATA_BASE}/${path}`);
    if (!r.ok) throw new Error(`Failed to load ${path}: ${r.status}`);
    return r.json() as Promise<T>;
  }

  function ncrAggregate(features: any[], year: number) {
    let canopyHa = 0;
    let totalHa = 0;
    for (const f of features) {
      const p = f.properties;
      const ha = p[`canopy_${year}_ha`];
      const tot = p.total_ha;
      if (ha != null) canopyHa += Number(ha);
      if (tot != null) totalHa += Number(tot);
    }
    const pct = totalHa > 0 ? (canopyHa / totalHa) * 100 : null;
    return { canopyHa, totalHa, pct };
  }

  async function init() {
    let lgus: any;
    try {
      lgus = await loadJSON<any>("per_lgu_canopy.geojson");
    } catch (e) {
      const el = document.getElementById("map");
      if (el) {
        el.innerHTML = '<div class="p-6 text-sm text-ink-500 font-mono">Per-LGU canopy data not yet published. Run `make compute` locally.</div>';
      }
      return;
    }

    const map = new maplibregl.Map({
      container: "map",
      style: {
        version: 8,
        sources: {
          osm: {
            type: "raster",
            tiles: [
              "https://a.tile.openstreetmap.org/{z}/{x}/{y}.png",
              "https://b.tile.openstreetmap.org/{z}/{x}/{y}.png",
              "https://c.tile.openstreetmap.org/{z}/{x}/{y}.png",
            ],
            tileSize: 256,
            attribution: "&copy; OpenStreetMap contributors",
          },
          meta: {
            type: "raster",
            tiles: ["/tiles/meta/{z}/{x}/{y}.png"],
            tileSize: 256,
            minzoom: 11,
            maxzoom: 14,
            attribution: "Meta Canopy Height v2 (CC-BY-4.0)",
          },
        },
        layers: [
          { id: "osm", type: "raster", source: "osm", paint: { "raster-saturation": -0.4, "raster-opacity": 0.7 } },
          { id: "meta-canopy", type: "raster", source: "meta", paint: { "raster-opacity": 0.85 } },
        ],
      },
      center: [121.03, 14.6],
      zoom: 10,
    });
    map.addControl(new maplibregl.NavigationControl({ showCompass: false }), "top-right");

    const slider = document.getElementById("year-slider");
    const yearLabel = document.getElementById("year-label");
    const sheet = document.getElementById("lgu-sheet");
    (document.getElementById("lgu-sheet-close") as HTMLButtonElement).onclick = () => sheet!.classList.add("translate-x-full");

    function applyYearStyle(year: number) {
      yearLabel!.textContent = String(year);
      for (const f of lgus.features) {
        const pct = f.properties[`canopy_${year}_pct`];
        f.properties._fill = colorForPct(pct);
        f.properties._current_pct = pct;
        f.properties._current_ha = f.properties[`canopy_${year}_ha`];
      }
      const src = map.getSource("lgus") as any;
      if (src) src.setData(lgus);

      const agg = ncrAggregate(lgus.features, year);
      document.getElementById("strip-total-pct")!.textContent = fmtPct(agg.pct, 2);
      document.getElementById("strip-total-ha")!.textContent = `${fmtHa(agg.canopyHa)} of ${fmtHa(agg.totalHa)} NCR`;
      if (year === 2026) {
        document.getElementById("strip-vs-denr")!.textContent = agg.pct != null ? fmtDelta(agg.pct - REF_PCT.denr_cited) : "n/a";
        document.getElementById("strip-vs-gfw")!.textContent = agg.pct != null ? fmtDelta(agg.pct - REF_PCT.gfw_dashboard) : "n/a";
      } else {
        document.getElementById("strip-vs-denr")!.textContent = "(2026)";
        document.getElementById("strip-vs-gfw")!.textContent = "(2026)";
      }
    }
    function ncrDelta() {
      const a19 = ncrAggregate(lgus.features, 2019).pct;
      const a26 = ncrAggregate(lgus.features, 2026).pct;
      return (a19 != null && a26 != null) ? a26 - a19 : null;
    }
    slider!.addEventListener("input", (e) => applyYearStyle(Number((e.target as HTMLInputElement).value)));

    map.on("load", () => {
      map.addSource("lgus", { type: "geojson", data: lgus });
      map.addLayer({
        id: "lgus-fill",
        type: "fill",
        source: "lgus",
        paint: { "fill-color": ["get", "_fill"], "fill-opacity": 0.5 },
      });
      map.addLayer({
        id: "lgus-outline",
        type: "line",
        source: "lgus",
        paint: { "line-color": INK, "line-width": 0.8, "line-opacity": 0.85 },
      });

      // pmtiles crown layer wiring lands in a follow-up; dim the toggle.
      const crownsLabel = document.querySelector('label:has(#layer-crowns)') as HTMLLabelElement | null;
      if (crownsLabel) crownsLabel.classList.add('opacity-40');

      // Click handlers
      map.on("click", "lgus-fill", (e) => {
        const f = e.features?.[0];
        if (!f) return;
        showLgu(f.properties.lgu_name);
      });
      map.on("mouseenter", "lgus-fill", () => (map.getCanvas().style.cursor = "pointer"));
      map.on("mouseleave", "lgus-fill", () => (map.getCanvas().style.cursor = ""));

      // Layer toggles
      const toggle = (id: string, layers: string[]) => {
        const cb = document.getElementById(id) as HTMLInputElement;
        cb.addEventListener("change", () => {
          const vis = cb.checked ? "visible" : "none";
          for (const ly of layers) {
            if (map.getLayer(ly)) map.setLayoutProperty(ly, "visibility", vis);
          }
        });
      };
      toggle("layer-meta", ["meta-canopy"]);
      toggle("layer-lgus", ["lgus-fill", "lgus-outline"]);

      applyYearStyle(Number((slider as HTMLInputElement).value));
      const d = ncrDelta();
      document.getElementById("strip-delta")!.textContent = d != null ? fmtDelta(d) : "n/a";
    });

    function showLgu(name: string) {
      const f = lgus.features.find((g: any) => g.properties.lgu_name === name);
      if (!f) return;
      const p = f.properties;
      const year = Number((slider as HTMLInputElement).value);
      document.getElementById("lgu-name")!.textContent = name;
      document.getElementById("lgu-pct-year-label")!.textContent = `${year} CANOPY`;
      document.getElementById("lgu-pct")!.textContent = fmtPct(p[`canopy_${year}_pct`]);
      document.getElementById("lgu-ha")!.textContent = `${fmtHa(p[`canopy_${year}_ha`])} of ${fmtHa(p.total_ha)} LGU area`;
      document.getElementById("lgu-delta")!.textContent = fmtDelta(p.canopy_delta_2019_2026_pct);
      document.getElementById("lgu-hansen")!.textContent = fmtHa(p.hansen_loss_ha_cumulative_2024);
      document.getElementById("lgu-esa")!.textContent = fmtPct(p.esa_tree_pct_2021);
      drawCurve(p);
      sheet!.classList.remove("translate-x-full");
    }
    function drawCurve(p: any) {
      const svg = document.getElementById("lgu-curve")!;
      svg.innerHTML = "";
      const series: (number | null)[] = YEARS.map((y) => p[`canopy_${y}_pct`] ?? null);
      const valid: number[] = series.filter((v): v is number => v != null);
      if (valid.length < 2) return;
      const minV = 0;
      const maxV = Math.max(...valid, MAX_PCT_FOR_COLOR);
      const W = 320, H = 90, padX = 6, padY = 8;
      const sx = (i: number) => padX + (i / (YEARS.length - 1)) * (W - 2 * padX);
      const sy = (v: number) => H - padY - ((v - minV) / (maxV - minV)) * (H - 2 * padY);
      const ns = "http://www.w3.org/2000/svg";

      // Baseline
      const base = document.createElementNS(ns, "line");
      base.setAttribute("x1", String(padX));
      base.setAttribute("x2", String(W - padX));
      base.setAttribute("y1", String(H - padY));
      base.setAttribute("y2", String(H - padY));
      base.setAttribute("stroke", "#a7a094");
      base.setAttribute("stroke-width", "0.5");
      svg.appendChild(base);

      // Area
      const path = document.createElementNS(ns, "path");
      let d = "";
      for (let i = 0; i < series.length; i++) {
        const v = series[i];
        if (v == null) continue;
        d += (d ? " L " : "M ") + sx(i).toFixed(1) + " " + sy(v).toFixed(1);
      }
      path.setAttribute("d", d);
      path.setAttribute("fill", "none");
      path.setAttribute("stroke", FOREST_GREEN);
      path.setAttribute("stroke-width", "1.6");
      svg.appendChild(path);

      for (let i = 0; i < series.length; i++) {
        const v = series[i];
        if (v == null) continue;
        const c = document.createElementNS(ns, "circle");
        c.setAttribute("cx", String(sx(i)));
        c.setAttribute("cy", String(sy(v)));
        c.setAttribute("r", "2.5");
        c.setAttribute("fill", FOREST_GREEN);
        svg.appendChild(c);
      }
      // Endpoint labels
      const lblL = document.createElementNS(ns, "text");
      lblL.setAttribute("x", String(padX));
      lblL.setAttribute("y", String(H - 1));
      lblL.setAttribute("font-size", "8");
      lblL.setAttribute("font-family", "JetBrains Mono, monospace");
      lblL.setAttribute("fill", "#6a6a6a");
      lblL.textContent = `${YEARS[0]} ${fmtPct(series[0])}`;
      svg.appendChild(lblL);
      const lblR = document.createElementNS(ns, "text");
      lblR.setAttribute("x", String(W - padX));
      lblR.setAttribute("y", String(H - 1));
      lblR.setAttribute("text-anchor", "end");
      lblR.setAttribute("font-size", "8");
      lblR.setAttribute("font-family", "JetBrains Mono, monospace");
      lblR.setAttribute("fill", "#6a6a6a");
      lblR.textContent = `${YEARS[YEARS.length - 1]} ${fmtPct(series[series.length - 1])}`;
      svg.appendChild(lblR);
    }

    // Bottom rankings table
    type Row = { name: string; pct2026: number | null; delta: number | null };
    const rows: Row[] = lgus.features
      .map((f: any) => ({
        name: f.properties.lgu_name,
        pct2026: f.properties.canopy_2026_pct ?? null,
        delta: f.properties.canopy_delta_2019_2026_pct ?? null,
      }))
      .filter((r: Row) => r.pct2026 != null)
      .sort((a: Row, b: Row) => (b.pct2026 ?? 0) - (a.pct2026 ?? 0));
    const tbody = document.getElementById("lgu-table-body");
    if (tbody) {
      tbody.innerHTML = rows.map((r: Row) => {
        const deltaColor = (r.delta ?? 0) < 0 ? "text-umber-700" : (r.delta ?? 0) > 0 ? "text-forest-700" : "text-ink-500";
        return `<tr class="cursor-pointer hover:bg-paper-tint" data-lgu="${r.name}">
          <td class="py-2 text-ink-900">${r.name}</td>
          <td class="py-2 text-right text-ink-900 font-medium">${fmtPct(r.pct2026)}</td>
          <td class="py-2 text-right ${deltaColor}">${fmtDelta(r.delta)}</td>
        </tr>`;
      }).join("");
      tbody.querySelectorAll("tr[data-lgu]").forEach((tr) => {
        tr.addEventListener("click", () => {
          showLgu((tr as HTMLTableRowElement).dataset.lgu || "");
          document.getElementById("map")?.scrollIntoView({ behavior: "smooth" });
        });
      });
    }
  }

  init().catch((err) => {
    console.error(err);
    const el = document.getElementById("map");
    if (el) el.innerHTML = '<div class="p-6 text-sm text-ink-500 font-mono">Map data failed to load. Check the browser console.</div>';
  });
</script>
