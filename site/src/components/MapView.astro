---
import { SERIES_START, SERIES_END } from "../lib/series";
---
<!-- ===== MAP HERO: immersive, full-viewport, overlaid controls ===== -->
<section id="map-hero" class="relative w-full overflow-hidden border-b border-ink-900" style="height: calc(100svh - 52px); min-height: 480px;">
  <div id="map" class="w-full h-full bg-paper-tint"></div>

  <!-- loading overlay -->
  <div
    id="map-loading"
    class="absolute inset-0 z-30 flex items-center justify-center bg-paper-tint/85 backdrop-blur-[1px] pointer-events-none transition-opacity duration-300"
    role="status"
    aria-live="polite"
  >
    <div class="flex items-center gap-3 font-mono text-[12px] uppercase tracking-[0.15em] text-ink-700">
      <span class="map-spinner inline-block w-4 h-4 border-2 border-ink-300 border-t-forest-700 rounded-full"></span>
      Loading the map…
    </div>
  </div>
  <!-- error overlay -->
  <div id="map-error" class="absolute inset-0 z-30 hidden items-center justify-center bg-paper-tint/95" role="alert">
    <p id="map-error-msg" class="font-mono text-[12px] text-umber-700 px-6 text-center leading-relaxed"></p>
  </div>

  <!-- INTRO + FIND panel (top-left) -->
  <div class="map-panel absolute top-3 left-3 z-20 w-[min(92vw,22rem)]">
    <p class="kicker text-sepia-700 mb-1.5">Metro Manila &middot; tree canopy</p>
    <h1 class="font-display text-ink-900 leading-[0.98] tracking-[-0.02em]" style="font-size: clamp(1.35rem, 3.4vw, 2rem);">
      How much of the city is under trees?
    </h1>
    <p class="text-[13px] text-ink-700 leading-[1.45] mt-2">
      Drag the year. Tap any place for its tree cover. Click a tree to see it from the sky.
    </p>
    <div class="mt-3 flex items-stretch gap-2">
      <input
        id="barangay-search"
        type="search"
        list="barangay-list"
        placeholder="find your barangay…"
        autocomplete="off"
        aria-label="Search for a barangay by name and zoom to it"
        class="map-focusable !cursor-text min-w-0 flex-1 border border-ink-300 bg-paper px-2.5 py-1.5 text-[13px] font-sans tracking-normal text-ink-900 placeholder:text-ink-500 disabled:opacity-40 disabled:!cursor-not-allowed"
      />
      <button id="geolocate-btn" type="button" class="map-btn shrink-0" aria-label="Find the tree cover near my location">Near me</button>
    </div>
    <datalist id="barangay-list"></datalist>
    <p id="barangay-search-msg" class="text-[12px] text-ink-500 mt-1.5 min-h-[1em]" aria-live="polite"></p>
  </div>

  <!-- LAYERS + key panel (top-right, collapsible) -->
  <details id="layers-panel" class="map-panel map-details absolute top-[17.5rem] right-3 sm:top-[4.25rem] z-20 w-[min(60vw,17rem)] sm:w-[min(86vw,17rem)]">
    <summary class="font-mono text-[11px] uppercase tracking-[0.16em] text-ink-700 cursor-pointer select-none flex items-center justify-between gap-2">
      <span>Layers &amp; key</span><span class="map-caret text-sepia-500">+</span>
    </summary>
    <div class="mt-3 space-y-3">
      <div class="flex flex-wrap gap-x-3 gap-y-1.5 items-center font-mono text-[11px] text-ink-700">
        <span class="text-sepia-500 uppercase tracking-[0.12em]">Base</span>
        <label class="flex items-center gap-1.5 cursor-pointer"><input type="radio" name="basemap" id="basemap-osm" value="osm" checked class="accent-forest-700 map-focusable" aria-label="Streets basemap (OpenStreetMap)" />streets</label>
        <label class="flex items-center gap-1.5 cursor-pointer"><input type="radio" name="basemap" id="basemap-sat" value="sat" class="accent-forest-700 map-focusable" aria-label="Satellite basemap (Esri)" />satellite</label>
      </div>
      <div class="grid grid-cols-1 gap-1.5 font-mono text-[11px] text-ink-700">
        <label class="flex items-center gap-1.5 cursor-pointer"><input type="checkbox" id="layer-lgus" checked class="accent-forest-700 map-focusable" aria-label="Toggle city tree-cover layer" />city tree cover (17)</label>
        <label class="flex items-center gap-1.5 cursor-pointer"><input type="checkbox" id="layer-barangays" class="accent-forest-700 map-focusable" aria-label="Toggle barangay tree-cover layer" />barangay tree cover (892)</label>
        <label class="flex items-center gap-1.5 cursor-pointer"><input type="checkbox" id="layer-crowns" checked class="accent-forest-700 map-focusable" aria-label="Toggle individual tree layer" />individual trees (242k)</label>
        <label class="flex items-center gap-1.5 cursor-pointer"><input type="checkbox" id="layer-meta" checked class="accent-forest-700 map-focusable" aria-label="Toggle canopy-height shading layer" />canopy-height shading</label>
      </div>
      <div class="flex items-center gap-2 font-mono text-[10px] uppercase tracking-[0.1em] text-sepia-500 pt-2 border-t border-ink-300/60">
        <span class="text-ink-500">less</span>
        <span class="inline-block h-2.5 flex-1 border border-ink-300" style="background:linear-gradient(to right,#ffffe5,#d9f0a3,#78c679,#238443,#004529)" role="img" aria-label="Fill scale, light for low tree cover through dark green for high tree cover"></span>
        <span class="text-ink-500">more trees</span>
      </div>
      <div class="grid grid-cols-1 gap-1 font-mono text-[10px] text-ink-500">
        <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 shrink-0" style="background:#1f6634"></span>confirmed by street maps</span>
        <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 shrink-0" style="background:#d4a019"></span>tall canopy (8 m or more)</span>
        <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 shrink-0" style="background:#9ca3af"></span>likely tree (5 to 8 m)</span>
      </div>
    </div>
  </details>

  <!-- YEAR scrubber + live readout + presets (bottom) -->
  <div class="map-panel absolute bottom-3 left-3 right-3 z-20 mx-auto w-[min(96vw,52rem)]">
    <div class="flex items-end justify-between gap-3 mb-1.5">
      <div class="flex items-baseline gap-2.5">
        <span class="kicker text-sepia-500">Year</span>
        <span id="year-label" class="font-display font-medium text-2xl sm:text-3xl tabular-nums text-ink-900 leading-none">{SERIES_END}</span>
      </div>
      <div class="text-right font-mono text-[11px] sm:text-[12px] text-ink-700 leading-tight">
        <span class="text-sepia-500 uppercase tracking-[0.1em]">tree cover </span>
        <span id="strip-total-pct" class="text-forest-700 font-medium tabular-nums">--</span>
        <span class="text-ink-300 mx-1">&middot;</span>
        <span class="text-sepia-500 uppercase tracking-[0.1em]">vs {SERIES_START} </span>
        <span id="strip-delta" class="tabular-nums">--</span>
        <span id="strip-total-ha" class="hidden"></span>
      </div>
    </div>
    <input
      id="year-slider"
      type="range"
      min={SERIES_START}
      max={SERIES_END}
      step="1"
      value={SERIES_END}
      class="editorial-slider map-focusable w-full"
      aria-label={`Map year, ${SERIES_START} to ${SERIES_END}`}
      aria-valuetext={`${SERIES_END}`}
    />
    <div class="flex items-center justify-between gap-2 mt-1 font-mono text-[10px] uppercase tracking-[0.12em] text-ink-500">
      <span class="shrink-0">{SERIES_START}</span>
      <div class="flex flex-wrap items-center justify-center gap-x-2 gap-y-1">
        <span class="text-sepia-500 hidden sm:inline">jump to</span>
        <button class="map-chip" type="button" data-lng="121.085" data-lat="14.73" data-zoom="13.2">La Mesa watershed</button>
        <button class="map-chip" type="button" data-lng="121.05" data-lat="14.66" data-zoom="11.6">Quezon City</button>
        <button class="map-chip" type="button" data-lng="120.985" data-lat="14.595" data-zoom="12.4">Manila core</button>
        <button id="share-link-btn" class="map-chip" type="button" aria-label="Copy a link to this map view">copy link</button>
      </div>
      <span class="shrink-0">{SERIES_END}</span>
    </div>
  </div>

  <!-- onboarding hint (dismissible) -->
  <div id="onboard-hint" class="absolute left-1/2 -translate-x-1/2 bottom-[13rem] sm:bottom-[7rem] z-20 hidden w-[min(92vw,26rem)]">
    <div class="map-panel flex items-center gap-3 text-[12px] text-ink-800 leading-snug">
      <span>Tip: click any green tree to see a live satellite photo of that exact spot.</span>
      <button id="onboard-dismiss" class="map-chip shrink-0" type="button">got it</button>
    </div>
  </div>
</section>

<!-- ===== BELOW THE FOLD: quick context band ===== -->
<section class="max-w-[1280px] mx-auto px-5 sm:px-10 pt-12">
  <div class="grid grid-cols-3 gap-x-6 sm:gap-x-10 gap-y-4 pb-8 border-b border-ink-300">
    <div>
      <p class="kicker text-sepia-500 mb-1.5">trees mapped</p>
      <p class="stat-medium leading-none">242,810</p>
      <p class="font-mono text-[11px] mt-2 text-ink-500 leading-relaxed">individual crowns across NCR</p>
    </div>
    <div>
      <p class="kicker text-sepia-500 mb-1.5">places</p>
      <p class="stat-medium leading-none">17<span class="text-umber-500"> + </span>892</p>
      <p class="font-mono text-[11px] mt-2 text-ink-500 leading-relaxed">cities/town + barangays</p>
    </div>
    <div>
      <p class="kicker text-sepia-500 mb-1.5">years</p>
      <p class="stat-medium leading-none">{SERIES_START}<span class="text-umber-500">&ndash;</span>{String(SERIES_END).slice(-2)}</p>
      <p class="font-mono text-[11px] mt-2 text-ink-500 leading-relaxed">annual snapshots ({SERIES_END} provisional)</p>
    </div>
  </div>
</section>

<!-- ===== Per-place ranking + reading note ===== -->
<section class="max-w-[1280px] mx-auto px-5 sm:px-10 py-8 grid md:grid-cols-editorial-wide gap-x-12 gap-y-8">
  <div>
    <p class="kicker text-sepia-500 mb-3">every city, ranked by tree cover</p>
    <table class="w-full text-sm font-mono tabular-nums">
      <thead class="border-b border-ink-900">
        <tr class="text-left text-[11px] uppercase tracking-[0.12em] text-sepia-500">
          <th class="py-2 font-medium">place</th>
          <th class="py-2 font-medium text-right">{SERIES_END}</th>
          <th class="py-2 font-medium text-right">vs {SERIES_START}</th>
        </tr>
      </thead>
      <tbody id="lgu-table-body" class="divide-y divide-ink-300/50"></tbody>
    </table>
    <p class="font-mono text-[11px] text-ink-500 mt-3">Tap a row to fly there and open its detail.</p>
  </div>
  <aside class="max-w-narrow">
    <p class="kicker text-sepia-500 mb-3">reading note</p>
    <p class="text-sm leading-[1.7] text-ink-700">
      Quezon City carries the regional average, held up by the La Mesa watershed, the UP Diliman campus, and the Wack Wack greens. Drop QC and the Metro Manila figure roughly halves.
    </p>
    <p class="text-sm leading-[1.7] text-ink-700 mt-4">
      Manila, Navotas, and Pasay are <span class="font-medium">structurally low</span>: dense reclamation and historic urban core. Their tree cover will not move with method choice; it is just very low.
    </p>
    <p class="text-sm leading-[1.7] text-ink-700 mt-4">
      These are annual snapshots, not a measured loss series. <a href="/report" class="text-umber-700 underline decoration-umber-500/50 underline-offset-2">Read the full report</a> for how the number is built and what it does and does not mean.
    </p>
  </aside>
</section>

<!-- Dismiss scrim behind the slide-over: click anywhere to close. -->
<div id="lgu-scrim" class="fixed inset-0 bg-ink-900/30 z-40 opacity-0 pointer-events-none transition-opacity duration-300" aria-hidden="true"></div>

<!-- SLIDE-OVER LGU DETAIL SHEET (right-anchored) -->
<aside id="lgu-sheet" role="dialog" aria-modal="true" aria-labelledby="lgu-name" tabindex="-1" class="fixed inset-y-0 right-0 w-full max-w-md bg-paper border-l border-ink-900 transform translate-x-full transition-transform duration-300 z-50 overflow-y-auto shadow-xl">
  <div class="border-b border-ink-900 px-5 py-3 flex items-baseline justify-between sticky top-0 bg-paper">
    <p class="kicker text-sepia-500">place detail</p>
    <button id="lgu-sheet-close" class="font-mono text-sm text-ink-700 hover:text-forest-700">close &times;</button>
  </div>
  <div class="px-5 py-5">
    <p class="kicker text-ink-500">NATIONAL CAPITAL REGION</p>
    <h2 id="lgu-name" class="font-display text-display-2 text-ink-900 mt-1 mb-6 leading-none">--</h2>

    <div class="grid grid-cols-2 gap-x-6 gap-y-5 border-y border-ink-900 py-5">
      <div>
        <p class="kicker text-sepia-500 mb-1" id="lgu-pct-year-label">tree cover</p>
        <p id="lgu-pct" class="font-display font-medium text-3xl text-forest-700 tabular-nums leading-none">--</p>
        <p id="lgu-ha" class="font-mono text-[10px] text-ink-500 mt-1.5 leading-relaxed">--</p>
      </div>
      <div>
        <p class="kicker text-sepia-500 mb-1">change since {SERIES_START}</p>
        <p id="lgu-delta" class="font-display font-medium text-3xl text-umber-700 tabular-nums leading-none">--</p>
        <p class="font-mono text-[10px] text-ink-500 mt-1.5 leading-relaxed">points of tree cover</p>
      </div>
    </div>

    <p class="kicker text-sepia-500 mt-6 mb-3">year by year</p>
    <svg id="lgu-curve" viewBox="0 0 320 90" class="w-full h-24" preserveAspectRatio="none"></svg>

    <div class="mt-6 pt-5 border-t border-ink-300 space-y-4">
      <div class="flex items-baseline justify-between gap-3">
        <p class="kicker text-sepia-500">tree loss 2001-2025 (satellite)</p>
        <p id="lgu-hansen" class="font-mono font-medium tabular-nums text-ink-900">--</p>
      </div>
      <div class="flex items-baseline justify-between gap-3">
        <p class="kicker text-sepia-500">second-source check, 2021</p>
        <p id="lgu-esa" class="font-mono font-medium tabular-nums text-ink-900">--</p>
      </div>
    </div>
  </div>
</aside>

<script>
  import maplibregl from "maplibre-gl";
  import "maplibre-gl/dist/maplibre-gl.css";
  import { interpolateYlGn } from "d3-scale-chromatic";
  import { Protocol } from "pmtiles";
  import centroid from "@turf/centroid";

  // Loading / error overlay helpers.
  function hideLoading() {
    const el = document.getElementById("map-loading");
    if (el) el.style.opacity = "0";
    window.setTimeout(() => el && (el.style.display = "none"), 320);
  }
  function showError(msg: string) {
    const load = document.getElementById("map-loading");
    if (load) load.style.display = "none";
    const err = document.getElementById("map-error");
    const errMsg = document.getElementById("map-error-msg");
    if (errMsg) errMsg.textContent = msg;
    if (err) {
      err.classList.remove("hidden");
      err.classList.add("flex");
    }
  }

  // Register the pmtiles:// protocol with MapLibre so vector tile sources can
  // load straight from a static .pmtiles archive (no tile server needed).
  const pmtilesProtocol = new Protocol();
  maplibregl.addProtocol("pmtiles", pmtilesProtocol.tile);

  const DATA_BASE = "/data";
  const YEARS = Array.from({ length: 8 }, (_, i) => 2019 + i);
  const MAX_PCT_FOR_COLOR = 22;
  const FOREST_GREEN = "#1f3d2b";
  const INK = "#1a1a1a";

  function colorForPct(pct: number | null | undefined): string {
    if (pct == null) return "#efe9d8";
    const t = Math.max(0, Math.min(1, pct / MAX_PCT_FOR_COLOR));
    return interpolateYlGn(0.15 + t * 0.85);
  }
  function fmtPct(n: number | null | undefined, digits = 2): string {
    return n == null ? "n/a" : `${n.toFixed(digits)}%`;
  }
  function fmtHa(n: number | null | undefined): string {
    if (n == null) return "n/a";
    // Drop "kha" jargon: keep readable hectare numbers for laymen.
    return `${Math.round(n).toLocaleString()} ha`;
  }
  function fmtDelta(n: number | null | undefined): string {
    if (n == null) return "n/a";
    const sign = n > 0 ? "+" : "";
    // "pts" reads more clearly to laymen than the academic "pp" abbreviation.
    return `${sign}${n.toFixed(2)} pts`;
  }

  async function loadJSON<T = any>(path: string): Promise<T> {
    const r = await fetch(`${DATA_BASE}/${path}`);
    if (!r.ok) throw new Error(`Failed to load ${path}: ${r.status}`);
    return r.json() as Promise<T>;
  }

  function ncrAggregate(features: any[], year: number) {
    let canopyHa = 0;
    let totalHa = 0;
    for (const f of features) {
      const p = f.properties;
      const ha = p[`canopy_${year}_ha`];
      const tot = p.total_ha;
      if (ha != null) canopyHa += Number(ha);
      if (tot != null) totalHa += Number(tot);
    }
    const pct = totalHa > 0 ? (canopyHa / totalHa) * 100 : null;
    return { canopyHa, totalHa, pct };
  }

  async function init() {
    let lgus: any;
    try {
      lgus = await loadJSON<any>("per_lgu_canopy.geojson");
    } catch (e) {
      showError("The map data could not be loaded. Please check your connection and retry.");
      return;
    }

    // Shareable view state: year + center + zoom, read from the querystring on
    // load and written back as the user explores so any view can be linked.
    function readState() {
      const q = new URLSearchParams(location.search);
      const y = parseInt(q.get("y") || "", 10);
      const lat = parseFloat(q.get("lat") || "");
      const lng = parseFloat(q.get("lng") || "");
      const z = parseFloat(q.get("z") || "");
      return {
        year: Number.isFinite(y) && y >= YEARS[0] && y <= YEARS[YEARS.length - 1] ? y : null,
        center: Number.isFinite(lat) && Number.isFinite(lng) ? ([lng, lat] as [number, number]) : null,
        zoom: Number.isFinite(z) ? z : null,
      };
    }
    const initState = readState();

    const map = new maplibregl.Map({
      container: "map",
      style: {
        version: 8,
        sources: {
          osm: {
            type: "raster",
            tiles: [
              "https://a.tile.openstreetmap.org/{z}/{x}/{y}.png",
              "https://b.tile.openstreetmap.org/{z}/{x}/{y}.png",
              "https://c.tile.openstreetmap.org/{z}/{x}/{y}.png",
            ],
            tileSize: 256,
            attribution: "&copy; OpenStreetMap contributors",
          },
          sat: {
            type: "raster",
            tiles: [
              "https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}",
            ],
            tileSize: 256,
            maxzoom: 19,
            attribution: "Imagery &copy; Esri, Maxar, Earthstar Geographics",
          },
          meta: {
            type: "raster",
            tiles: ["/tiles/meta/{z}/{x}/{y}.png"],
            tileSize: 256,
            minzoom: 11,
            maxzoom: 14,
            attribution: "Meta Canopy Height v2 (CC-BY-4.0)",
          },
        },
        layers: [
          { id: "osm", type: "raster", source: "osm", paint: { "raster-saturation": -0.4, "raster-opacity": 0.7 } },
          { id: "sat", type: "raster", source: "sat", layout: { visibility: "none" } },
          { id: "meta-canopy", type: "raster", source: "meta", paint: { "raster-opacity": 0.85 } },
        ],
      },
      center: initState.center || [121.05, 14.65],
      zoom: initState.zoom || 12,
      maxZoom: 16,
      minZoom: 9,
      clickTolerance: 6,  // 2x the default; helps land clicks on small crown polygons
    });
    // Expose for debugging from devtools / agent-browser:
    if (typeof window !== "undefined") {
      (window as any).__map = map;
      (window as any).maplibregl = maplibregl;
    }
    map.addControl(new maplibregl.NavigationControl({ showCompass: false }), "top-right");
    // The hero sizes with svh/calc; make sure the GL canvas matches once laid out.
    window.requestAnimationFrame(() => map.resize());
    window.addEventListener("resize", () => map.resize());

    const slider = document.getElementById("year-slider");
    const yearLabel = document.getElementById("year-label");
    if (initState.year) {
      (slider as HTMLInputElement).value = String(initState.year);
      (slider as HTMLInputElement).setAttribute("aria-valuetext", String(initState.year));
      yearLabel!.textContent = String(initState.year);
    }
    const sheet = document.getElementById("lgu-sheet");
    const scrim = document.getElementById("lgu-scrim");
    const sheetClose = document.getElementById("lgu-sheet-close") as HTMLButtonElement;
    function openSheet() {
      sheet!.classList.remove("translate-x-full");
      if (scrim) {
        scrim.classList.remove("opacity-0", "pointer-events-none");
        scrim.classList.add("opacity-100");
      }
      sheetClose?.focus();
    }
    function closeSheet() {
      sheet!.classList.add("translate-x-full");
      if (scrim) {
        scrim.classList.add("opacity-0", "pointer-events-none");
        scrim.classList.remove("opacity-100");
      }
    }
    function sheetIsOpen() {
      return !sheet!.classList.contains("translate-x-full");
    }
    sheetClose.onclick = closeSheet;
    scrim?.addEventListener("click", closeSheet);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && sheetIsOpen()) closeSheet();
    });

    function applyYearStyle(year: number) {
      yearLabel!.textContent = String(year);
      for (const f of lgus.features) {
        const pct = f.properties[`canopy_${year}_pct`];
        f.properties._fill = colorForPct(pct);
        f.properties._current_pct = pct;
        f.properties._current_ha = f.properties[`canopy_${year}_ha`];
      }
      const src = map.getSource("lgus") as any;
      if (src) src.setData(lgus);

      const agg = ncrAggregate(lgus.features, year);
      document.getElementById("strip-total-pct")!.textContent = fmtPct(agg.pct, 2);
      document.getElementById("strip-total-ha")!.textContent = `${fmtHa(agg.canopyHa)} of ${fmtHa(agg.totalHa)} in NCR`;
    }
    function ncrDelta() {
      const aStart = ncrAggregate(lgus.features, YEARS[0]).pct;
      const aEnd = ncrAggregate(lgus.features, YEARS[YEARS.length - 1]).pct;
      return (aStart != null && aEnd != null) ? aEnd - aStart : null;
    }
    slider!.addEventListener("input", (e) => {
      const v = (e.target as HTMLInputElement).value;
      (e.target as HTMLInputElement).setAttribute("aria-valuetext", v);
      applyYearStyle(Number(v));
    });

    map.on("load", () => {
      map.addSource("lgus", { type: "geojson", data: lgus });
      map.addLayer({
        id: "lgus-fill",
        type: "fill",
        source: "lgus",
        paint: { "fill-color": ["get", "_fill"], "fill-opacity": 0.22 },
      });
      map.addLayer({
        id: "lgus-outline",
        type: "line",
        source: "lgus",
        paint: { "line-color": INK, "line-width": 0.8, "line-opacity": 0.85 },
      });

      // 242,810 tree-crown polygons via pmtiles, tagged confirmed/new/candidate.
      //   confirmed (~3.6%): OSM-corroborated (natural=tree halo or in a forest/park/wood polygon)
      //   new       (~50.7%): Meta-derived, p95 height >= 8m, no OSM tag (tall canopy)
      //   candidate (~45.6%): Meta-derived, p95 height 5-8m, no OSM tag (lower-confidence)
      try {
        map.addSource("crowns", {
          type: "vector",
          url: "pmtiles:///data/tree_crowns_ncr_tagged.pmtiles",
          minzoom: 11,
          maxzoom: 16,
          attribution: "Meta Canopy Height v2 derived crown polygons (CC-BY-4.0)",
        });
        map.addLayer({
          id: "crowns-fill",
          type: "fill",
          source: "crowns",
          "source-layer": "crowns",
          minzoom: 12,
          paint: {
            "fill-color": [
              "match", ["get", "status"],
              "confirmed", "#1f6634",  // forest green - OSM corroborated
              "new",       "#d4a019",  // umber/yellow - tall canopy (Meta-derived)
              "candidate", "#9ca3af",  // gray - lower-confidence (Meta-derived)
              "#1f3d2b",
            ],
            "fill-opacity": [
              "interpolate", ["linear"], ["zoom"],
              12, 0.45,
              14, 0.65,
              16, 0.8,
            ],
          },
        });
        map.addLayer({
          id: "crowns-outline",
          type: "line",
          source: "crowns",
          "source-layer": "crowns",
          minzoom: 14,
          paint: {
            "line-color": [
              "match", ["get", "status"],
              "confirmed", "#13251c",
              "new",       "#8b6d10",
              "candidate", "#5a4f3a",
              "#13251c",
            ],
            "line-width": 0.4,
            "line-opacity": 0.6,
          },
        });
      } catch (e) {
        // pmtiles unavailable; dim the toggle so users know
        const crownsLabel = document.querySelector('label:has(#layer-crowns)') as HTMLLabelElement | null;
        if (crownsLabel) crownsLabel.classList.add('opacity-40');
        console.warn('pmtiles crown layer failed to load:', e);
      }

      // Click handlers. Order matters: the LGU handler must run AFTER the
      // crown handler so it can see _crownConsumed and bail. The crown
      // registration is below, after crownPopupHTML is defined; we use a
      // late-bound deferred LGU handler to enforce that ordering.
      const lguClickHandler = (e: any) => {
        if (e.originalEvent?._crownConsumed) return;
        const f = e.features?.[0];
        if (!f) return;
        showLgu(f.properties.lgu_name);
      };
      // (LGU handler is attached after the crown handler below.)
      map.on("mouseenter", "lgus-fill", () => (map.getCanvas().style.cursor = "pointer"));
      map.on("mouseleave", "lgus-fill", () => (map.getCanvas().style.cursor = ""));

      // Click a tree-crown polygon -> popup with an Esri satellite snapshot of
      // that exact location so users can visually verify whether the model
      // landed on a real tree. SolarMap.PH does the same for solar-panel
      // detections; this is the canopy-version of that interaction.
      const STATUS_META: Record<string, { color: string; label: string }> = {
        confirmed: { color: "#1f6634", label: "confirmed by street maps" },
        new:       { color: "#d4a019", label: "not in street maps · tall canopy" },
        candidate: { color: "#9ca3af", label: "not in street maps · likely tree" },
      };
      function crownPopupHTML(f: any): string {
        const g = f.geometry;
        const coords = g.type === "Polygon" ? g.coordinates[0]
                     : g.type === "MultiPolygon" ? g.coordinates[0][0]
                     : [];
        if (!coords.length) return "";
        let minLon = 1e9, maxLon = -1e9, minLat = 1e9, maxLat = -1e9;
        for (const [lon, lat] of coords) {
          if (lon < minLon) minLon = lon; if (lon > maxLon) maxLon = lon;
          if (lat < minLat) minLat = lat; if (lat > maxLat) maxLat = lat;
        }
        // Expand bbox to ~50 m context around the crown
        const padLon = Math.max(0.0005, (maxLon - minLon) * 1.8);
        const padLat = Math.max(0.0005, (maxLat - minLat) * 1.8);
        const bbox = [
          minLon - padLon, minLat - padLat,
          maxLon + padLon, maxLat + padLat,
        ].join(",");
        const W = 420, H = 420;
        const img = `https://services.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/export?bbox=${bbox}&size=${W},${H}&imageSR=4326&bboxSR=4326&format=jpg&f=image`;
        const p = f.properties || {};
        const status = String(p.status || "new");
        const meta = STATUS_META[status] || { color: "#1f3d2b", label: status };
        const isNum = (v: any) => typeof v === "number" && !Number.isNaN(v);
        const area = isNum(p.area_m2) ? `${Number(p.area_m2).toFixed(0)} m²` : "--";
        const p50 = isNum(p.p50_height_m) ? `${Number(p.p50_height_m).toFixed(1)} m` : "--";
        const p95 = isNum(p.p95_height_m) ? `${Number(p.p95_height_m).toFixed(1)} m` : "--";
        const lgu_raw = p.lgu_name;
        const lgu = (typeof lgu_raw === "string" && lgu_raw && lgu_raw !== "null") ? lgu_raw : "n/a";
        const cx = (minLon + maxLon) / 2;
        const cy = (minLat + maxLat) / 2;
        const osmLink = `https://www.openstreetmap.org/?mlat=${cy}&mlon=${cx}&zoom=19`;
        return `
<div style="font-family: 'PT Serif', serif; max-width: ${W}px; padding: 4px;">
  <div style="position: relative; width: ${W}px; height: ${H}px; background:#eee; overflow:hidden; border:1px solid #1a1a1a;">
    <img src="${img}" alt="Esri aerial of crown" style="width:${W}px;height:${H}px;display:block;" />
    <div style="position:absolute; left:8px; top:8px; padding:3px 8px; background:${meta.color}; color:white; font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:0.10em; text-transform:uppercase; font-weight:600;">${status}</div>
  </div>
  <div style="font-family:'JetBrains Mono',monospace; font-size:11px; line-height:1.5; color:#1a1a1a; margin-top:8px;">
    <div style="font-size:12px;"><b>${meta.label}</b></div>
    <div style="color:#5a4f3a; margin-top:2px;">LGU: ${lgu}</div>
    <div style="color:#5a4f3a;">Area: ${area} &nbsp;&middot;&nbsp; p50 height: ${p50} &nbsp;&middot;&nbsp; p95 height: ${p95}</div>
    <div style="margin-top:6px;">
      <a href="${osmLink}" target="_blank" rel="noopener" style="color:#1f6634; text-decoration:underline;">open this point in OSM &rarr;</a>
    </div>
    <div style="color:#837d6a; font-size:10px; margin-top:6px;">Imagery: Esri / Maxar / Earthstar Geographics. Detection: Meta v2 canopy height &gt;5 m + NDVI 0.62 calibration.</div>
  </div>
</div>`;
      }

      map.on("click", "crowns-fill", (e) => {
        const f = e.features?.[0];
        if (!f) return;
        const html = crownPopupHTML(f);
        if (!html) return;
        // Prevent the click bubbling to lgus-fill (which would open the LGU sheet)
        if ((e as any).originalEvent) (e as any).originalEvent._crownConsumed = true;
        new maplibregl.Popup({ maxWidth: "460px", closeButton: true })
          .setLngLat(e.lngLat)
          .setHTML(html)
          .addTo(map);
      });
      map.on("mouseenter", "crowns-fill", () => (map.getCanvas().style.cursor = "pointer"));
      map.on("mouseleave", "crowns-fill", () => (map.getCanvas().style.cursor = ""));

      // Now attach the LGU click handler (after the crown click handler so
      // _crownConsumed is set first).
      map.on("click", "lgus-fill", lguClickHandler);

      // Layer toggles
      const toggle = (id: string, layers: string[]) => {
        const cb = document.getElementById(id) as HTMLInputElement;
        cb.addEventListener("change", () => {
          const vis = cb.checked ? "visible" : "none";
          for (const ly of layers) {
            if (map.getLayer(ly)) map.setLayoutProperty(ly, "visibility", vis);
          }
        });
      };
      toggle("layer-meta", ["meta-canopy"]);
      toggle("layer-crowns", ["crowns-fill", "crowns-outline"]);
      toggle("layer-lgus", ["lgus-fill", "lgus-outline"]);

      // Basemap radio: OSM streets vs Esri satellite imagery.
      // When satellite is on, OSM is hidden; the Meta canopy overlay also drops to
      // 0.55 opacity so users can see the underlying aerial photo and visually
      // verify whether the crown polygons land on real trees.
      const setBasemap = (which: "osm" | "sat") => {
        if (map.getLayer("osm")) map.setLayoutProperty("osm", "visibility", which === "osm" ? "visible" : "none");
        if (map.getLayer("sat")) map.setLayoutProperty("sat", "visibility", which === "sat" ? "visible" : "none");
        if (map.getLayer("meta-canopy")) {
          map.setPaintProperty("meta-canopy", "raster-opacity", which === "sat" ? 0.55 : 0.85);
        }
      };
      document.getElementById("basemap-osm")?.addEventListener("change", () => setBasemap("osm"));
      document.getElementById("basemap-sat")?.addEventListener("change", () => setBasemap("sat"));

      applyYearStyle(Number((slider as HTMLInputElement).value));
      const d = ncrDelta();
      document.getElementById("strip-delta")!.textContent = d != null ? fmtDelta(d) : "n/a";

      // Barangay canopy layer (892 polygons, the v6/v9 canopy-density model, not
      // the crown layer). Loaded lazily the first time the toggle is switched on
      // so the initial map paint stays light.
      setupBarangays(map);

      // ---- shareable URL writer (debounced) ----
      let stTimer: number | undefined;
      function writeState(immediate = false) {
        if (stTimer) window.clearTimeout(stTimer);
        const run = () => {
          const c = map.getCenter();
          const q = new URLSearchParams();
          q.set("y", String((slider as HTMLInputElement).value));
          q.set("lng", c.lng.toFixed(4));
          q.set("lat", c.lat.toFixed(4));
          q.set("z", map.getZoom().toFixed(2));
          history.replaceState(null, "", location.pathname + "?" + q.toString());
        };
        if (immediate) run();
        else stTimer = window.setTimeout(run, 400);
      }
      map.on("moveend", () => writeState());
      slider!.addEventListener("input", () => writeState());

      const msgEl = document.getElementById("barangay-search-msg");
      const setMsg = (t: string) => {
        if (msgEl) msgEl.textContent = t;
      };

      // ---- "jump to" presets ----
      document.querySelectorAll<HTMLButtonElement>("[data-lng][data-lat][data-zoom]").forEach((b) => {
        b.addEventListener("click", () => {
          map.flyTo({
            center: [parseFloat(b.dataset.lng!), parseFloat(b.dataset.lat!)],
            zoom: parseFloat(b.dataset.zoom!),
            speed: 1.1,
          });
        });
      });

      // ---- geolocate: fly to the visitor's neighbourhood ----
      const geoBtn = document.getElementById("geolocate-btn") as HTMLButtonElement | null;
      geoBtn?.addEventListener("click", () => {
        if (!navigator.geolocation) {
          setMsg("Location is not available on this device.");
          return;
        }
        const original = geoBtn.textContent;
        geoBtn.textContent = "…";
        geoBtn.disabled = true;
        navigator.geolocation.getCurrentPosition(
          (pos) => {
            geoBtn.textContent = original;
            geoBtn.disabled = false;
            const lng = pos.coords.longitude;
            const lat = pos.coords.latitude;
            const inNCR = lng > 120.85 && lng < 121.18 && lat > 14.3 && lat < 14.82;
            map.flyTo({ center: [lng, lat], zoom: inNCR ? 14.5 : 11, speed: 1.3 });
            setMsg(inNCR ? "Showing your area." : "You appear to be outside Metro Manila.");
          },
          () => {
            geoBtn.textContent = original;
            geoBtn.disabled = false;
            setMsg("Could not get your location.");
          },
          { enableHighAccuracy: true, timeout: 8000, maximumAge: 60000 },
        );
      });

      // ---- copy a link to the current view ----
      const shareBtn = document.getElementById("share-link-btn") as HTMLButtonElement | null;
      shareBtn?.addEventListener("click", async () => {
        writeState(true);
        try {
          await navigator.clipboard.writeText(location.href);
          const o = shareBtn.textContent;
          shareBtn.textContent = "copied!";
          window.setTimeout(() => (shareBtn.textContent = o), 1400);
        } catch {
          setMsg("Copy failed. Copy the address bar instead.");
        }
      });

      // ---- layers panel: open on desktop, collapsed on small screens ----
      const layersPanel = document.getElementById("layers-panel") as HTMLDetailsElement | null;
      if (layersPanel && window.matchMedia("(min-width: 768px)").matches) layersPanel.open = true;

      // ---- onboarding hint (first visit only) ----
      const hint = document.getElementById("onboard-hint");
      let onboarded = false;
      try {
        onboarded = !!localStorage.getItem("leaves_onboarded");
      } catch {}
      if (hint && !onboarded) hint.classList.remove("hidden");
      const dismissHint = () => {
        hint?.classList.add("hidden");
        try {
          localStorage.setItem("leaves_onboarded", "1");
        } catch {}
      };
      document.getElementById("onboard-dismiss")?.addEventListener("click", dismissHint);

      // ---- one-time year auto-sweep so the slider visibly does something ----
      let swept = false;
      try {
        swept = !!localStorage.getItem("leaves_swept");
      } catch {}
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (!swept && !reduce && !initState.year) {
        const s = slider as HTMLInputElement;
        const end = YEARS[YEARS.length - 1];
        let y = YEARS[0];
        let iv = 0;
        const setY = (yy: number) => {
          s.value = String(yy);
          s.setAttribute("aria-valuetext", String(yy));
          applyYearStyle(yy);
        };
        const markSwept = () => {
          try {
            localStorage.setItem("leaves_swept", "1");
          } catch {}
        };
        // If the visitor grabs the slider mid-sweep, stop and leave it on their
        // value. The listener removes itself so it can never hijack a later drag.
        const onInterrupt = () => {
          window.clearInterval(iv);
          s.removeEventListener("input", onInterrupt);
          markSwept();
        };
        setY(y);
        iv = window.setInterval(() => {
          y++;
          if (y > end) {
            window.clearInterval(iv);
            s.removeEventListener("input", onInterrupt);
            markSwept();
            return;
          }
          setY(y);
        }, 520);
        s.addEventListener("input", onInterrupt);
      }

      hideLoading();
    });

    // Surface fatal style/source errors (bad tiles, blocked CDN) to the user.
    map.on("error", (e: any) => {
      console.warn("maplibre error:", e?.error || e);
    });

    function showLgu(name: string) {
      const f = lgus.features.find((g: any) => g.properties.lgu_name === name);
      if (!f) return;
      const p = f.properties;
      const year = Number((slider as HTMLInputElement).value);
      document.getElementById("lgu-name")!.textContent = name;
      document.getElementById("lgu-pct-year-label")!.textContent = `${year} tree cover`;
      document.getElementById("lgu-pct")!.textContent = fmtPct(p[`canopy_${year}_pct`]);
      document.getElementById("lgu-ha")!.textContent = `${fmtHa(p[`canopy_${year}_ha`])} of ${fmtHa(p.total_ha)} LGU area`;
      document.getElementById("lgu-delta")!.textContent = fmtDelta(p[`canopy_delta_${YEARS[0]}_${YEARS[YEARS.length - 1]}_pct`]);
      document.getElementById("lgu-hansen")!.textContent = fmtHa(p.hansen_loss_ha_cumulative_2024);
      document.getElementById("lgu-esa")!.textContent = fmtPct(p.esa_tree_pct_2021);
      drawCurve(p);
      openSheet();
    }
    function drawCurve(p: any) {
      const svg = document.getElementById("lgu-curve")!;
      svg.innerHTML = "";
      const series: (number | null)[] = YEARS.map((y) => p[`canopy_${y}_pct`] ?? null);
      const valid: number[] = series.filter((v): v is number => v != null);
      if (valid.length < 2) return;
      const minV = 0;
      const maxV = Math.max(...valid, MAX_PCT_FOR_COLOR);
      const W = 320, H = 90, padX = 6, padY = 8;
      const sx = (i: number) => padX + (i / (YEARS.length - 1)) * (W - 2 * padX);
      const sy = (v: number) => H - padY - ((v - minV) / (maxV - minV)) * (H - 2 * padY);
      const ns = "http://www.w3.org/2000/svg";

      // Baseline
      const base = document.createElementNS(ns, "line");
      base.setAttribute("x1", String(padX));
      base.setAttribute("x2", String(W - padX));
      base.setAttribute("y1", String(H - padY));
      base.setAttribute("y2", String(H - padY));
      base.setAttribute("stroke", "#a7a094");
      base.setAttribute("stroke-width", "0.5");
      svg.appendChild(base);

      // Area
      const path = document.createElementNS(ns, "path");
      let d = "";
      for (let i = 0; i < series.length; i++) {
        const v = series[i];
        if (v == null) continue;
        d += (d ? " L " : "M ") + sx(i).toFixed(1) + " " + sy(v).toFixed(1);
      }
      path.setAttribute("d", d);
      path.setAttribute("fill", "none");
      path.setAttribute("stroke", FOREST_GREEN);
      path.setAttribute("stroke-width", "1.6");
      svg.appendChild(path);

      for (let i = 0; i < series.length; i++) {
        const v = series[i];
        if (v == null) continue;
        const c = document.createElementNS(ns, "circle");
        c.setAttribute("cx", String(sx(i)));
        c.setAttribute("cy", String(sy(v)));
        c.setAttribute("r", "2.5");
        c.setAttribute("fill", FOREST_GREEN);
        svg.appendChild(c);
      }
      // Endpoint labels
      const lblL = document.createElementNS(ns, "text");
      lblL.setAttribute("x", String(padX));
      lblL.setAttribute("y", String(H - 1));
      lblL.setAttribute("font-size", "8");
      lblL.setAttribute("font-family", "JetBrains Mono, monospace");
      lblL.setAttribute("fill", "#6a6a6a");
      lblL.textContent = `${YEARS[0]} ${fmtPct(series[0])}`;
      svg.appendChild(lblL);
      const lblR = document.createElementNS(ns, "text");
      lblR.setAttribute("x", String(W - padX));
      lblR.setAttribute("y", String(H - 1));
      lblR.setAttribute("text-anchor", "end");
      lblR.setAttribute("font-size", "8");
      lblR.setAttribute("font-family", "JetBrains Mono, monospace");
      lblR.setAttribute("fill", "#6a6a6a");
      lblR.textContent = `${YEARS[YEARS.length - 1]} ${fmtPct(series[series.length - 1])}`;
      svg.appendChild(lblR);
    }

    // ── Barangay canopy layer + name search ──────────────────────────────
    // These 892 values are the published human-calibrated canopy model
    // (canopy_pct_model_<year>), NOT the Meta-derived crown layer.
    function setupBarangays(map: any) {
      const cb = document.getElementById("layer-barangays") as HTMLInputElement | null;
      const search = document.getElementById("barangay-search") as HTMLInputElement | null;
      const datalist = document.getElementById("barangay-list");
      const searchMsg = document.getElementById("barangay-search-msg");
      if (!cb) return;

      let bgons: any = null;
      let loaded = false;
      let loading = false;
      // name (lowercased) -> { lon, lat, display }
      const index = new Map<string, { lon: number; lat: number; display: string }>();

      function styleBarangays(year: number) {
        if (!bgons) return;
        for (const f of bgons.features) {
          const pct = f.properties[`canopy_pct_model_${year}`];
          f.properties._bfill = colorForPct(pct);
          f.properties._bpct = pct;
        }
        const src = map.getSource("barangays") as any;
        if (src) src.setData(bgons);
      }

      async function ensureLoaded(): Promise<boolean> {
        if (loaded) return true;
        if (loading) return false;
        loading = true;
        try {
          bgons = await loadJSON<any>("per_barangay_canopy_model.geojson");
        } catch (e) {
          loading = false;
          cb!.checked = false;
          cb!.disabled = true;
          const lbl = cb!.closest("label");
          if (lbl) lbl.classList.add("opacity-40");
          console.warn("barangay layer failed to load:", e);
          return false;
        }

        const year = Number((slider as HTMLInputElement).value);
        for (const f of bgons.features) {
          const pct = f.properties[`canopy_pct_model_${year}`];
          f.properties._bfill = colorForPct(pct);
          f.properties._bpct = pct;
          const name = f.properties.barangay_name;
          const lgu = f.properties.lgu_name;
          if (typeof name === "string" && name) {
            try {
              const c = centroid(f as any);
              const [lon, lat] = c.geometry.coordinates as [number, number];
              const display = lgu ? `${name} · ${lgu}` : name;
              index.set(`${name}, ${lgu}`.toLowerCase(), { lon, lat, display });
              // Also key by bare name for first-match lookups.
              const bare = name.toLowerCase();
              if (!index.has(bare)) index.set(bare, { lon, lat, display });
            } catch {
              // skip malformed geometry
            }
          }
        }

        map.addSource("barangays", { type: "geojson", data: bgons });
        // Insert below the LGU outline so LGU borders stay visible on top.
        const before = map.getLayer("lgus-outline") ? "lgus-outline" : undefined;
        // Added hidden; shown when the toggle is checked or a search runs, so the
        // layer state always matches the checkbox.
        const startVis = cb!.checked ? "visible" : "none";
        map.addLayer(
          {
            id: "barangays-fill",
            type: "fill",
            source: "barangays",
            layout: { visibility: startVis },
            paint: { "fill-color": ["get", "_bfill"], "fill-opacity": 0.45 },
          },
          before,
        );
        map.addLayer(
          {
            id: "barangays-outline",
            type: "line",
            source: "barangays",
            layout: { visibility: startVis },
            paint: { "line-color": INK, "line-width": 0.4, "line-opacity": 0.5 },
          },
          before,
        );

        map.on("click", "barangays-fill", (e: any) => {
          const f = e.features?.[0];
          if (!f) return;
          const p = f.properties || {};
          const yr = Number((slider as HTMLInputElement).value);
          const pct = p[`canopy_pct_model_${yr}`];
          const ha = p[`canopy_ha_model_${yr}`];
          new maplibregl.Popup({ maxWidth: "300px", closeButton: true })
            .setLngLat(e.lngLat)
            .setHTML(
              `<div style="font-family:'JetBrains Mono',monospace;font-size:11px;line-height:1.6;color:#1a1a1a;padding:10px 12px;">
                <div style="font-family:'PT Serif',serif;font-size:14px;">${p.barangay_name ?? "Barangay"}</div>
                <div style="color:#5a4f3a;">${p.lgu_name ?? ""}</div>
                <div style="margin-top:6px;">${yr}${yr === 2026 ? " (provisional)" : ""}: <b>${pct == null ? "n/a" : Number(pct).toFixed(2) + "%"}</b></div>
                <div style="color:#5a4f3a;">${ha == null ? "" : Number(ha).toFixed(1) + " ha canopy of " + Number(p.total_ha).toFixed(0) + " ha"}</div>
                <div style="color:#675f4a;font-size:10px;margin-top:6px;">Source: human-calibrated canopy model (published).</div>
              </div>`,
            )
            .addTo(map);
        });
        map.on("mouseenter", "barangays-fill", () => (map.getCanvas().style.cursor = "pointer"));
        map.on("mouseleave", "barangays-fill", () => (map.getCanvas().style.cursor = ""));

        // Populate the search datalist with "Name · LGU" options.
        if (datalist) {
          const opts: string[] = [];
          for (const f of bgons.features) {
            const name = f.properties.barangay_name;
            const lgu = f.properties.lgu_name;
            if (typeof name === "string" && name) {
              opts.push(`<option value="${name}, ${lgu}"></option>`);
            }
          }
          datalist.innerHTML = opts.join("");
        }

        loaded = true;
        loading = false;
        return true;
      }

      // Re-style barangay fills when the year changes (only if loaded).
      slider!.addEventListener("input", (e) => {
        if (loaded) styleBarangays(Number((e.target as HTMLInputElement).value));
      });

      cb.addEventListener("change", async () => {
        if (cb.checked) {
          const ok = await ensureLoaded();
          if (!ok) return;
          for (const ly of ["barangays-fill", "barangays-outline"]) {
            if (map.getLayer(ly)) map.setLayoutProperty(ly, "visibility", "visible");
          }
        } else {
          for (const ly of ["barangays-fill", "barangays-outline"]) {
            if (map.getLayer(ly)) map.setLayoutProperty(ly, "visibility", "none");
          }
        }
      });

      function runSearch() {
        if (!search) return;
        const q = search.value.trim().toLowerCase();
        if (!q) {
          if (searchMsg) searchMsg.textContent = "";
          return;
        }
        let hit = index.get(q);
        if (!hit) {
          // fall back to first prefix match
          for (const [k, v] of index) {
            if (k.startsWith(q)) {
              hit = v;
              break;
            }
          }
        }
        if (!hit) {
          if (searchMsg) searchMsg.textContent = "no match";
          return;
        }
        if (searchMsg) searchMsg.textContent = hit.display;
        map.flyTo({ center: [hit.lon, hit.lat], zoom: 14.5, speed: 1.2 });
      }

      // Preload the geojson (and datalist options) the first time the user
      // focuses the search field, so autocomplete is populated as they type.
      search?.addEventListener("focus", () => {
        ensureLoaded();
      });

      search?.addEventListener("change", () => {
        ensureLoaded().then((ok) => {
          if (!ok) return;
          if (!cb.checked) {
            cb.checked = true;
            for (const ly of ["barangays-fill", "barangays-outline"]) {
              if (map.getLayer(ly)) map.setLayoutProperty(ly, "visibility", "visible");
            }
          }
          runSearch();
        });
      });
      search?.addEventListener("keydown", (e) => {
        if ((e as KeyboardEvent).key === "Enter") {
          e.preventDefault();
          ensureLoaded().then((ok) => {
            if (!ok) return;
            if (!cb.checked) {
              cb.checked = true;
              for (const ly of ["barangays-fill", "barangays-outline"]) {
                if (map.getLayer(ly)) map.setLayoutProperty(ly, "visibility", "visible");
              }
            }
            runSearch();
          });
        }
      });
    }

    // Bottom rankings table - latest-epoch pct and series delta are read
    // dynamically from the GeoJSON via SERIES_START / SERIES_END keys.
    const yStart = YEARS[0];
    const yEnd = YEARS[YEARS.length - 1];
    const latestKey = `canopy_${yEnd}_pct`;
    const deltaKey = `canopy_delta_${yStart}_${yEnd}_pct`;
    type Row = { name: string; pctLatest: number | null; delta: number | null };
    const rows: Row[] = lgus.features
      .map((f: any) => ({
        name: f.properties.lgu_name,
        pctLatest: f.properties[latestKey] ?? null,
        delta: f.properties[deltaKey] ?? null,
      }))
      .filter((r: Row) => r.pctLatest != null)
      .sort((a: Row, b: Row) => (b.pctLatest ?? 0) - (a.pctLatest ?? 0));
    const tbody = document.getElementById("lgu-table-body");
    if (tbody) {
      tbody.innerHTML = rows.map((r: Row) => {
        const deltaColor = (r.delta ?? 0) < 0 ? "text-umber-700" : (r.delta ?? 0) > 0 ? "text-forest-700" : "text-ink-500";
        return `<tr class="cursor-pointer hover:bg-paper-tint" data-lgu="${r.name}">
          <td class="py-2 text-ink-900">${r.name}</td>
          <td class="py-2 text-right text-ink-900 font-medium">${fmtPct(r.pctLatest)}</td>
          <td class="py-2 text-right ${deltaColor}">${fmtDelta(r.delta)}</td>
        </tr>`;
      }).join("");
      tbody.querySelectorAll("tr[data-lgu]").forEach((tr) => {
        tr.addEventListener("click", () => {
          showLgu((tr as HTMLTableRowElement).dataset.lgu || "");
          document.getElementById("map")?.scrollIntoView({ behavior: "smooth" });
        });
      });
    }
  }

  init().catch((err) => {
    console.error(err);
    showError("Map data failed to load. Check the browser console, then retry.");
  });
</script>
